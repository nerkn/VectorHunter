{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DetectionBox",
  "type": "object",
  "properties": {
    "bbox": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4
    },
    "class_id": { "type": "integer" },
    "class_name": { "type": "string" },
    "confidence": { "type": "number" },
    "track_id": { "type": ["integer", "null"] }
  },
  "required": ["bbox", "class_id", "class_name", "confidence"]
}